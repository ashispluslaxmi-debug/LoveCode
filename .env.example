# LoveCode AI - Environment Configuration Example
# Copy this file to .env and fill in your values

# Groq API key for LLM access
# GROQ_API_KEY=

# OpenRouter API key for LLM access
# OPENROUTER_API_KEY=

# Together AI API key
# TOGETHER_API_KEY=

# HuggingFace API key
# HUGGINGFACE_API_KEY=

# OpenAI API key (fallback)
# OPENAI_API_KEY=

# Ollama server URL
# OLLAMA_URL=

# Log level (debug|info|warn|error)
# LOVECODE_LOG_LEVEL=

# Override default model
# LOVECODE_MODEL=

# Override default theme
# LOVECODE_THEME=

# Override approval mode (smart|strict|permissive)
# LOVECODE_APPROVAL_MODE=

# Enable telemetry (true|false)
# LOVECODE_TELEMETRY=
